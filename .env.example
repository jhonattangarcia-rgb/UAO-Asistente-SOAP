# Example environment variables for UAO-Asistente-SOAP
OPENROUTER_API_KEY="sk-REPLACE_WITH_KEY"
OPENROUTER_MODEL="openai/whisper-large-v3-turbo"
API_SECRET_KEY="TU_API_KEY_DE_GROQ_AQUI"
